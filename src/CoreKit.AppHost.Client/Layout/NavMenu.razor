@inject AuthenticationStateProvider AuthenticationStateProvider

<div class="top-row">
    <div class="brand-block">
        <a class="navbar-brand" href="">CoreKit</a>
        <p>Enterprise application core</p>
    </div>

    <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
        <span>Menu</span>
    </button>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="nav flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-label">Home</span>
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="system">
                <span class="nav-label">System</span>
            </NavLink>
        </div>
        @if (!isControlPlaneHost)
        {
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="tenant-notes">
                    <span class="nav-label">Tenant Notes</span>
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="customers">
                    <span class="nav-label">Customers</span>
                </NavLink>
            </div>
            <AuthorizeView>
                <Authorized>
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="tenant-admin">
                            <span class="nav-label">Tenant Admin</span>
                        </NavLink>
                    </div>
                </Authorized>
            </AuthorizeView>
        }
        <AuthorizeView Roles="Admin">
            <Authorized>
                @if (isControlPlaneHost)
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="platform-admin">
                            <span class="nav-label">Platform Admin</span>
                        </NavLink>
                    </div>
                }
            </Authorized>
        </AuthorizeView>
        <AuthorizeView>
            <Authorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="logout">
                        <span class="nav-label">Logout</span>
                    </NavLink>
                </div>
            </Authorized>
            <NotAuthorized>
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="login">
                        <span class="nav-label">Login</span>
                    </NavLink>
                </div>
            </NotAuthorized>
        </AuthorizeView>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;
    private bool isControlPlaneHost;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isControlPlaneHost = authState.User.HasClaim("corekit:control-plane", "true");
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
