@inherits LayoutComponentBase

<div class="page">
    <aside class="sidebar">
        <NavMenu />
    </aside>

    <main>
        <header class="top-row">
            <div>
                <p class="eyebrow">CoreKit</p>
                <strong>AppHost Client</strong>
            </div>
            <div>
                <AuthorizeView>
                    <Authorized>
                        <span class="environment-badge">Signed in as @context.User.Identity?.Name</span>
                    </Authorized>
                    <NotAuthorized>
                        <span class="environment-badge">Phase 3 complete</span>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </header>

        <article class="content">
            @Body
        </article>
    </main>
</div>
