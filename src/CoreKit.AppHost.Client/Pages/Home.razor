@page "/"
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>CoreKit</PageTitle>

<section class="hero">
    <div class="hero-copy">
        <p class="eyebrow">Phase 2</p>
        <h1>CoreKit application shell is now in place.</h1>
        <p class="lead">
            This client is the future entry point for authentication, tenant-aware workflows,
            and business modules running on top of the CoreKit platform.
        </p>
    </div>

    <div class="hero-card">
        <h2>Current focus</h2>
        <ul>
            <li>Minimal API startup on the server</li>
            <li>Blazor WebAssembly shell on the client</li>
            <li>Preparation for auth, tenancy, and RPC</li>
        </ul>
    </div>
</section>

<section class="grid">
    <article class="panel">
        <h2>Authentication</h2>
        @if (isAuthenticated)
        {
            <p>Signed in as <strong>@userName</strong>.</p>
        }
        else
        {
            <p>Not signed in yet. Use the login page to test the new auth flow.</p>
        }
    </article>

    <article class="panel">
        <h2>Client role</h2>
        <p>
            The client will host routing, layout, auth state, and user-facing workflows across modules.
        </p>
    </article>

    <article class="panel">
        <h2>Next milestone</h2>
        <p>
            Extend the hosted flow and continue into tenancy and RPC after the bootstrap auth pass.
        </p>
    </article>
</section>

@code {
    private bool isAuthenticated;
    private string? userName;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        isAuthenticated = authState.User.Identity?.IsAuthenticated == true;
        userName = authState.User.Identity?.Name;
    }
}
