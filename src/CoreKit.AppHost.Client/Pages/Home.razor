@page "/"
<PageTitle>CoreKit</PageTitle>

<section class="hero">
    <div class="hero-copy">
        <p class="eyebrow">Phase 3</p>
        <h1>CoreKit now has a working hosted cookie authentication flow.</h1>
        <p class="lead">
            The app host is ready for tenant-aware work after the first end-to-end auth pass:
            login, logout, protected routing, and refresh-safe user state.
        </p>
    </div>

    <div class="hero-card">
        <h2>Current focus</h2>
        <ul>
            <li>Hosted login and logout through the server</li>
            <li>Protected routes backed by cookie auth</li>
            <li>Preparation for tenant resolution</li>
        </ul>
    </div>
</section>

<section class="grid">
    <article class="panel">
        <h2>Authentication</h2>
        <AuthorizeView>
            <Authorized>
                <p>Signed in as <strong>@context.User.Identity?.Name</strong>.</p>
            </Authorized>
            <NotAuthorized>
                <p>Not signed in yet. Use the login page to test the hosted auth flow.</p>
            </NotAuthorized>
        </AuthorizeView>
    </article>

    <article class="panel">
        <h2>Client role</h2>
        <p>
            The client will host routing, layout, auth state, and user-facing workflows across modules.
        </p>
    </article>

    <article class="panel">
        <h2>Next milestone</h2>
        <p>
            Move into tenant catalog and tenant resolution after this auth phase closes.
        </p>
    </article>
</section>
