@page "/platform-login"
@layout PlatformLayout
@inject AuthApiClient AuthApiClient
@inject ServerAuthenticationStateProvider AuthenticationStateProvider
@inject NavigationManager NavigationManager

<PageTitle>Platform Login</PageTitle>

<section class="panel login-panel">
    <p class="eyebrow">Control Plane</p>
    <h1>Sign in to platform administration</h1>
    <p>Use the global admin account on the control-plane host to manage tenant catalog and provisioning workflows.</p>

    @if (!string.IsNullOrWhiteSpace(ReturnUrl))
    {
        <p class="text-muted">After sign-in, you will return to the platform page you originally requested.</p>
    }

    <EditForm Model="@loginRequest" OnValidSubmit="@HandleLoginAsync" class="login-form">
        <DataAnnotationsValidator />

        <label>
            <span>User name</span>
            <InputText @bind-Value="loginRequest.UserName" />
        </label>

        <label>
            <span>Password</span>
            <InputText @bind-Value="loginRequest.Password" type="password" />
        </label>

        <label class="checkbox-row">
            <InputCheckbox @bind-Value="loginRequest.RememberMe" />
            <span>Remember me</span>
        </label>

        <button class="primary-button" type="submit" disabled="@isSubmitting">
            @(isSubmitting ? "Signing in..." : "Sign in to control plane")
        </button>
    </EditForm>

    @if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <p class="error-text">@errorMessage</p>
    }

    <div class="seed-box">
        <strong>Admin account</strong>
        <p>User name: <code>admin</code></p>
        <p>Password: <code>Admin1234</code></p>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private LoginFormModel loginRequest = new()
    {
        UserName = "admin",
        Password = "Admin1234"
    };

    private bool isSubmitting;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();

        if (authState.User.Identity?.IsAuthenticated == true)
        {
            NavigationManager.NavigateTo(ResolveTargetUrl(), forceLoad: false);
        }
    }

    private async Task HandleLoginAsync()
    {
        isSubmitting = true;
        errorMessage = null;

        var success = await AuthApiClient.LoginAsync(
            new LoginRequest(
                loginRequest.UserName,
                loginRequest.Password,
                loginRequest.RememberMe));

        isSubmitting = false;

        if (!success)
        {
            errorMessage = "Sign in failed. Check the credentials and try again.";
            return;
        }

        await AuthenticationStateProvider.RefreshUserStateAsync();
        NavigationManager.NavigateTo(ResolveTargetUrl());
    }

    private string ResolveTargetUrl()
    {
        if (string.IsNullOrWhiteSpace(ReturnUrl))
        {
            return "/platform-admin";
        }

        return ReturnUrl.StartsWith("/", StringComparison.Ordinal)
            && !ReturnUrl.StartsWith("//", StringComparison.Ordinal)
            ? ReturnUrl
            : "/platform-admin";
    }

    private sealed class LoginFormModel
    {
        public string UserName { get; set; } = string.Empty;

        public string Password { get; set; } = string.Empty;

        public bool RememberMe { get; set; }
    }
}
