@page "/system"
@attribute [Authorize]

<PageTitle>System</PageTitle>

<section class="panel">
    <p class="eyebrow">System</p>
    <h1>Application bootstrap status</h1>
    <p>
        CoreKit is currently running with a solution skeleton, an AppHost pair, shared building blocks,
        and initial module boundaries for Identity and Tenancy.
    </p>
</section>

<section class="grid">
    <article class="panel">
        <h2>Server endpoints</h2>
        <ul>
            <li>`/` root system status</li>
            <li>`/api/system/info` basic server metadata</li>
            <li>`/health` health checks</li>
        </ul>
    </article>

    <article class="panel">
        <h2>Upcoming areas</h2>
        <ul>
            <li>Client-side RPC workflows</li>
            <li>Module framework standardization</li>
            <li>Module-specific UI workflows</li>
        </ul>
    </article>
</section>
