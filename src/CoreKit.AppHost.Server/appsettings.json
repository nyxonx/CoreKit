{
  "Application": {
    "Name": "CoreKit",
    "Host": "Server"
  },
  "ConnectionStrings": {
    "TenantCatalogDatabase": "Data Source=corekit.catalog.db",
    "DefaultTenantDatabase": "Data Source=corekit.bootstrap.tenant.db"
  },
  "Tenancy": {
    "Seed": {
      "Identifier": "bootstrap",
      "Name": "Bootstrap Tenant",
      "Host": "localhost"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
