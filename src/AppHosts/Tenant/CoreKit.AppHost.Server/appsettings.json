{
  "Application": {
    "Name": "CoreKit",
    "Host": "TenantAppHost"
  },
  "ConnectionStrings": {
    "TenantCatalogDatabase": "corekit.catalog.db",
    "IdentityDatabase": "corekit.identity.db"
  },
  "Tenancy": {
    "DatabaseRoot": "../../../../localdata",
    "Registry": {
      "Mode": "Remote",
      "BaseUrl": "https://admin.local:7282"
    }
  },
  "Caching": {
    "TenantCatalog": {
      "TtlSeconds": 60
    }
  },
  "BackgroundJobs": {
    "TenantCatalogMaintenance": {
      "IntervalMinutes": 5
    }
  },
  "Logging": {
    "Console": {
      "IncludeScopes": true
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
