@page "/platform-admin"
@attribute [Authorize(Roles = "Admin")]
@layout PlatformLayout
@inject AuthApiClient AuthApiClient
@inject ITenantAdministrationClient TenantAdministrationClient
@inject IIdentityAdminModuleClient IdentityAdminModuleClient

<PageTitle>Platform Administration</PageTitle>

<section class="platform-hero">
    <div class="platform-hero-copy panel">
        <p class="eyebrow">Control Plane</p>
        <h1>Platform administration</h1>
        <p class="lead">
            This surface is reserved for global tenant catalog and provisioning workflows, outside of any individual tenant workspace.
        </p>

        <div class="platform-badges">
            <span class="status-chip status-chip-active">Host: admin.local</span>
            <span class="status-chip @(isGlobalAdmin ? "status-chip-active" : "status-chip-muted")">
                Access: @(isGlobalAdmin ? "global admin" : "restricted")
            </span>
        </div>
    </div>

    <aside class="platform-hero-card panel">
        <h2>Operating rules</h2>
        <ul class="platform-rules">
            <li>Use this host only for platform-wide tenant management.</li>
            <li>Use tenant hosts for membership, role changes, and tenant-scoped operations.</li>
            <li>Each new tenant should get a unique identifier and dedicated host.</li>
        </ul>
    </aside>
</section>

@if (!isGlobalAdmin)
{
    <section class="panel">
        <h2>Global admin access required</h2>
        <p>
            Only platform administrators can review the tenant catalog or provision a new tenant from this control-plane surface.
        </p>
    </section>
}
else
{
    <section class="grid platform-overview">
        <article class="panel">
            <p class="eyebrow">Catalog</p>
            <h2>@TenantCountLabel</h2>
            <p class="platform-panel-copy">Currently registered tenants in the shared catalog.</p>
        </article>

        <article class="panel">
            <p class="eyebrow">Provisioning</p>
            <h2>Ready</h2>
            <p class="platform-panel-copy">New tenant creation will write catalog metadata and run the provisioning flow.</p>
        </article>
    </section>

    <section class="grid platform-workspace">
        <article class="panel platform-form-panel">
            <div class="platform-section-header">
                <div>
                    <p class="eyebrow">Provision Tenant</p>
                    <h2>Create tenant</h2>
                </div>
                <p class="platform-hint">Identifier and host should stay stable after rollout.</p>
            </div>

            <EditForm Model="@this" OnValidSubmit="@HandleCreateTenantAsync" class="platform-form">
                <label>
                    <span>Identifier</span>
                    <InputText @bind-Value="newTenantIdentifier" />
                    <small>Example: <code>acme</code></small>
                </label>

                <label>
                    <span>Name</span>
                    <InputText @bind-Value="newTenantName" />
                    <small>Human-readable tenant name.</small>
                </label>

                <label>
                    <span>Host</span>
                    <InputText @bind-Value="newTenantHost" />
                    <small>Example: <code>acme.local</code></small>
                </label>

                <button class="primary-button" type="submit" disabled="@isTenantSubmitting">
                    @(isTenantSubmitting ? "Provisioning..." : "Create tenant")
                </button>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(tenantFormMessage))
            {
                <p class="@TenantFormMessageClass">@tenantFormMessage</p>
            }
        </article>

        <article class="panel">
            <div class="platform-section-header">
                <div>
                    <p class="eyebrow">Tenant Catalog</p>
                    <h2>Registered tenants</h2>
                </div>
                <button class="secondary-button" @onclick="LoadTenantsAsync" disabled="@isCatalogLoading">
                    @(isCatalogLoading ? "Refreshing..." : "Refresh")
                </button>
            </div>

            @if (isCatalogLoading)
            {
                <p>Loading tenants...</p>
            }
            else if (!string.IsNullOrWhiteSpace(catalogError))
            {
                <p class="error-text">@catalogError</p>
            }
            else if (tenants.Count == 0)
            {
                <p>No tenants found.</p>
            }
            else
            {
                <div class="tenant-catalog-list">
                    @foreach (var tenant in tenants)
                    {
                        <article class="tenant-catalog-card @(IsSelectedTenant(tenant) ? "tenant-catalog-card-selected" : null)">
                            <div>
                                <strong>@tenant.Name</strong>
                                <p class="tenant-catalog-meta">@tenant.Identifier</p>
                            </div>
                            <div class="tenant-catalog-side">
                                <code>@tenant.Host</code>
                                <span class="tenant-state @(tenant.IsActive ? "tenant-state-active" : "tenant-state-inactive")">
                                    @(tenant.IsActive ? "Active" : "Inactive")
                                </span>
                                <button class="secondary-button tenant-select-button" @onclick="() => SelectTenant(tenant)">
                                    @(IsSelectedTenant(tenant) ? "Selected" : "Open")
                                </button>
                            </div>
                        </article>
                    }
                </div>
            }
        </article>
    </section>

    <section class="grid platform-detail-grid">
        <article class="panel">
            <div class="platform-section-header">
                <div>
                    <p class="eyebrow">Tenant Detail</p>
                    <h2>@(selectedTenant?.Name ?? "Select a tenant")</h2>
                </div>
            </div>

            @if (selectedTenant is null)
            {
                <p>Select a tenant from the catalog to inspect its host, identifier, and current platform status.</p>
            }
            else
            {
                <dl class="platform-detail-list">
                    <div>
                        <dt>Identifier</dt>
                        <dd><code>@selectedTenant.Identifier</code></dd>
                    </div>
                    <div>
                        <dt>Host</dt>
                        <dd><code>@selectedTenant.Host</code></dd>
                    </div>
                    <div>
                        <dt>Status</dt>
                        <dd>@(selectedTenant.IsActive ? "Active" : "Inactive")</dd>
                    </div>
                </dl>

                <p class="platform-detail-note">
                    Platform lifecycle actions and tenant membership management will attach to this selected tenant in the next Phase 14 slices.
                </p>

                <button class="secondary-button" @onclick="HandleSelectedTenantActivationToggleAsync" disabled="@isTenantActivationSubmitting">
                    @(isTenantActivationSubmitting
                        ? "Saving..."
                        : selectedTenant.IsActive
                            ? "Deactivate tenant"
                            : "Activate tenant")
                </button>

                @if (!string.IsNullOrWhiteSpace(tenantLifecycleMessage))
                {
                    <p class="@TenantLifecycleMessageClass">@tenantLifecycleMessage</p>
                }
            }
        </article>

        <article class="panel">
            <div class="platform-section-header">
                <div>
                    <p class="eyebrow">Membership</p>
                    <h2>Platform tenant access</h2>
                </div>
            </div>

            @if (selectedTenant is null)
            {
                <p>Choose a tenant first, then platform-level membership management can operate on that tenant safely.</p>
            }
            else
            {
                <p class="platform-detail-note">
                    Global admin is working on tenant <code>@selectedTenant.Identifier</code> from the control-plane host.
                </p>

                <EditForm Model="@this" OnValidSubmit="@HandlePlatformMembershipSubmitAsync" class="platform-form">
                    <label>
                        <span>User name</span>
                        <InputText @bind-Value="platformTargetUserName" />
                        <small>Assign an existing identity user to the selected tenant.</small>
                    </label>

                    <label>
                        <span>Tenant role</span>
                        <InputSelect @bind-Value="platformSelectedRole">
                            @foreach (var role in availableRoles)
                            {
                                <option value="@role">@role</option>
                            }
                        </InputSelect>
                    </label>

                    <button class="primary-button" type="submit" disabled="@isPlatformMembershipSubmitting">
                        @(isPlatformMembershipSubmitting ? "Saving..." : "Assign or update membership")
                    </button>
                </EditForm>

                @if (!string.IsNullOrWhiteSpace(platformMembershipMessage))
                {
                    <p class="@PlatformMembershipMessageClass">@platformMembershipMessage</p>
                }

                <div class="platform-membership-list">
                    <div class="platform-section-header">
                        <div>
                            <p class="eyebrow">Tenant Memberships</p>
                            <h3>Current access list</h3>
                        </div>
                        <button class="secondary-button" @onclick="LoadSelectedTenantMembershipsAsync" disabled="@isMembershipLoading">
                            @(isMembershipLoading ? "Refreshing..." : "Refresh")
                        </button>
                    </div>

                    @if (isMembershipLoading)
                    {
                        <p>Loading memberships...</p>
                    }
                    else if (!string.IsNullOrWhiteSpace(membershipLoadError))
                    {
                        <p class="error-text">@membershipLoadError</p>
                    }
                    else if (selectedTenantMemberships.Count == 0)
                    {
                        <p>No memberships yet for this tenant.</p>
                    }
                    else
                    {
                        <div class="tenant-catalog-list">
                            @foreach (var membership in selectedTenantMemberships)
                            {
                                <article class="tenant-catalog-card">
                                    <div>
                                        <strong>@membership.UserName</strong>
                                        <p class="tenant-catalog-meta">@membership.Role</p>
                                    </div>
                                    <div class="tenant-catalog-side">
                                        <span class="tenant-state @(membership.IsActive ? "tenant-state-active" : "tenant-state-inactive")">
                                            @(membership.IsActive ? "Active" : "Inactive")
                                        </span>
                                        <button class="secondary-button tenant-select-button" @onclick="() => HandleMembershipActivationToggleAsync(membership)" disabled="@isPlatformMembershipSubmitting">
                                            @(membership.IsActive ? "Deactivate" : "Activate")
                                        </button>
                                    </div>
                                </article>
                            }
                        </div>
                    }
                </div>
            }
        </article>
    </section>
}

@code {
    private readonly List<TenantCatalogDto> tenants = [];
    private readonly List<TenantMembershipDto> selectedTenantMemberships = [];
    private readonly string[] availableRoles = [TenantMembershipRoles.Admin, TenantMembershipRoles.Member];
    private string newTenantIdentifier = string.Empty;
    private string newTenantName = string.Empty;
    private string newTenantHost = string.Empty;
    private string platformTargetUserName = "admin";
    private string platformSelectedRole = TenantMembershipRoles.Member;
    private string? tenantFormMessage;
    private string? catalogError;
    private string? platformMembershipMessage;
    private string? membershipLoadError;
    private string? tenantLifecycleMessage;
    private bool isCatalogLoading = true;
    private bool isTenantSubmitting;
    private bool isMembershipLoading;
    private bool isPlatformMembershipSubmitting;
    private bool isTenantActivationSubmitting;
    private bool isGlobalAdmin;
    private bool lastCreateSucceeded;
    private bool lastPlatformMembershipSucceeded;
    private bool lastTenantLifecycleSucceeded;
    private TenantCatalogDto? selectedTenant;

    private string TenantCountLabel => $"{tenants.Count} tenant{(tenants.Count == 1 ? string.Empty : "s")}";

    private string TenantFormMessageClass => lastCreateSucceeded ? "success-text" : "error-text";

    private string PlatformMembershipMessageClass => lastPlatformMembershipSucceeded ? "success-text" : "error-text";

    private string TenantLifecycleMessageClass => lastTenantLifecycleSucceeded ? "success-text" : "error-text";

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthApiClient.GetAuthStateAsync();
        isGlobalAdmin = authState.Roles.Contains("Admin", StringComparer.OrdinalIgnoreCase);

        if (isGlobalAdmin)
        {
            await LoadTenantsAsync();
        }
        else
        {
            isCatalogLoading = false;
        }
    }

    private async Task LoadTenantsAsync()
    {
        isCatalogLoading = true;
        catalogError = null;

        var response = await TenantAdministrationClient.GetTenantsAsync();

        isCatalogLoading = false;

        if (!response.Succeeded)
        {
            catalogError = response.Errors.FirstOrDefault()?.Message ?? "Tenants could not be loaded.";
            tenants.Clear();
            return;
        }

        tenants.Clear();
        tenants.AddRange(response.Data ?? []);

        if (selectedTenant is not null)
        {
            selectedTenant = tenants.FirstOrDefault(tenant => tenant.Identifier == selectedTenant.Identifier);

            if (selectedTenant is null)
            {
                selectedTenantMemberships.Clear();
                membershipLoadError = null;
                isMembershipLoading = false;
            }
            else
            {
                await LoadSelectedTenantMembershipsAsync();
            }
        }
    }

    private async Task HandleCreateTenantAsync()
    {
        isTenantSubmitting = true;
        tenantFormMessage = null;
        lastCreateSucceeded = false;

        var response = await TenantAdministrationClient.CreateTenantAsync(
            new CreateTenantRpcRequest(newTenantIdentifier, newTenantName, newTenantHost));

        isTenantSubmitting = false;

        if (!response.Succeeded)
        {
            tenantFormMessage = response.Errors.FirstOrDefault()?.Message ?? "Tenant could not be created.";
            return;
        }

        lastCreateSucceeded = true;
        tenantFormMessage = $"Tenant '{response.Data?.Identifier}' was created and provisioning started successfully.";
        newTenantIdentifier = string.Empty;
        newTenantName = string.Empty;
        newTenantHost = string.Empty;

        await LoadTenantsAsync();

        if (response.Data is not null)
        {
            SelectTenant(response.Data);
        }
    }

    private void SelectTenant(TenantCatalogDto tenant)
    {
        selectedTenant = tenant;
        _ = InvokeAsync(LoadSelectedTenantMembershipsAsync);
    }

    private bool IsSelectedTenant(TenantCatalogDto tenant) =>
        string.Equals(selectedTenant?.Identifier, tenant.Identifier, StringComparison.OrdinalIgnoreCase);

    private async Task LoadSelectedTenantMembershipsAsync()
    {
        if (selectedTenant is null)
        {
            selectedTenantMemberships.Clear();
            membershipLoadError = null;
            isMembershipLoading = false;
            return;
        }

        isMembershipLoading = true;
        membershipLoadError = null;

        var response = await IdentityAdminModuleClient.GetTenantMembershipsForTenantAsync(
            new GetTenantMembershipsForTenantRpcRequest(selectedTenant.Identifier));

        isMembershipLoading = false;

        if (!response.Succeeded)
        {
            membershipLoadError = response.Errors.FirstOrDefault()?.Message ?? "Memberships could not be loaded.";
            selectedTenantMemberships.Clear();
            return;
        }

        selectedTenantMemberships.Clear();
        selectedTenantMemberships.AddRange(response.Data ?? []);
    }

    private async Task HandlePlatformMembershipSubmitAsync()
    {
        if (selectedTenant is null)
        {
            platformMembershipMessage = "Select a tenant before managing membership.";
            lastPlatformMembershipSucceeded = false;
            return;
        }

        isPlatformMembershipSubmitting = true;
        platformMembershipMessage = null;
        lastPlatformMembershipSucceeded = false;

        var response = await IdentityAdminModuleClient.UpsertTenantMembershipForTenantAsync(
            new UpsertTenantMembershipForTenantRpcRequest(
                selectedTenant.Identifier,
                platformTargetUserName,
                platformSelectedRole));

        isPlatformMembershipSubmitting = false;

        if (!response.Succeeded)
        {
            platformMembershipMessage = response.Errors.FirstOrDefault()?.Message ?? "Membership could not be saved.";
            return;
        }

        lastPlatformMembershipSucceeded = true;
        platformMembershipMessage =
            $"Membership saved for '{response.Data?.UserName}' on tenant '{selectedTenant.Identifier}'.";
        await LoadSelectedTenantMembershipsAsync();
    }

    private async Task HandleMembershipActivationToggleAsync(TenantMembershipDto membership)
    {
        if (selectedTenant is null)
        {
            return;
        }

        isPlatformMembershipSubmitting = true;
        platformMembershipMessage = null;
        lastPlatformMembershipSucceeded = false;

        var response = await IdentityAdminModuleClient.SetTenantMembershipActivationForTenantAsync(
            new SetTenantMembershipActivationForTenantRpcRequest(
                selectedTenant.Identifier,
                membership.UserName,
                !membership.IsActive));

        isPlatformMembershipSubmitting = false;

        if (!response.Succeeded)
        {
            platformMembershipMessage = response.Errors.FirstOrDefault()?.Message ?? "Membership state could not be updated.";
            return;
        }

        lastPlatformMembershipSucceeded = true;
        platformMembershipMessage =
            $"Membership for '{response.Data?.UserName}' is now {((response.Data?.IsActive ?? false) ? "active" : "inactive")}.";
        await LoadSelectedTenantMembershipsAsync();
    }

    private async Task HandleSelectedTenantActivationToggleAsync()
    {
        if (selectedTenant is null)
        {
            return;
        }

        isTenantActivationSubmitting = true;
        tenantLifecycleMessage = null;
        lastTenantLifecycleSucceeded = false;

        var response = await TenantAdministrationClient.SetTenantActivationAsync(
            new SetTenantActivationRpcRequest(selectedTenant.Identifier, !selectedTenant.IsActive));

        isTenantActivationSubmitting = false;

        if (!response.Succeeded)
        {
            tenantLifecycleMessage = response.Errors.FirstOrDefault()?.Message ?? "Tenant state could not be updated.";
            return;
        }

        lastTenantLifecycleSucceeded = true;
        tenantLifecycleMessage =
            $"Tenant '{response.Data?.Identifier}' is now {((response.Data?.IsActive ?? false) ? "active" : "inactive")}.";

        await LoadTenantsAsync();
    }
}
