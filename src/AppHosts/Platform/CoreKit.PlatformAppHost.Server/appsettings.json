{
  "Application": {
    "Name": "CoreKit",
    "Host": "PlatformAppHost"
  },
  "ConnectionStrings": {
    "TenantCatalogDatabase": "Data Source=../../../../localdata/corekit.catalog.db",
    "IdentityDatabase": "Data Source=../../../../localdata/corekit.identity.db",
    "DefaultTenantDatabase": "Data Source=../../../../localdata/corekit.bootstrap.tenant.db",
    "ContosoTenantDatabase": "Data Source=../../../../localdata/corekit.contoso.tenant.db",
    "FabrikamTenantDatabase": "Data Source=../../../../localdata/corekit.fabrikam.tenant.db"
  },
  "Tenancy": {
    "Seed": {
      "Identifier": "bootstrap",
      "Name": "Bootstrap Tenant",
      "Host": "localhost"
    },
    "ControlPlaneHosts": [
      "admin.local"
    ]
  },
  "Caching": {
    "TenantCatalog": {
      "TtlSeconds": 60
    }
  },
  "BackgroundJobs": {
    "TenantCatalogMaintenance": {
      "IntervalMinutes": 5
    }
  },
  "Logging": {
    "Console": {
      "IncludeScopes": true
    },
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
